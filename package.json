{
  "name": "qpin-ios-network-location",
  "version": "1.0.0",
  "description": "Free iOS Network Location Changer — MITM Apple WLOC (WiFi/cell) responses via proxy tools",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsx scripts/build.ts",
    "build:scripts": "tsx scripts/build.ts scripts",
    "build:worker": "tsx scripts/build.ts worker",
    "build:web": "tsx scripts/build.ts web",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit && tsc --noEmit -p worker/tsconfig.json",
    "typecheck": "npm run lint",
    "dev:web": "tsx scripts/serve-web.ts",
    "dev:worker": "wrangler dev -c worker/wrangler.toml",
    "check": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "ios",
    "location",
    "wloc",
    "network-location",
    "surge",
    "shadowrocket",
    "quantumult-x",
    "qpin"
  ],
  "author": "QPin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arvinfuu/QPin-iOS-Network-Location"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260718.1",
    "@types/node": "^22.10.2",
    "esbuild": "0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "hono": "^4.6.14"
  },
  "engines": {
    "node": ">=22"
  }
}
